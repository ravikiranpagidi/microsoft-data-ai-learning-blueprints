{
  "name": "azure-lakehouse-starter-kit-retail-workflow",
  "format": "MULTI_TASK",
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "setup_catalog",
      "notebook_task": {
        "notebook_path": "/Repos/<repo>/azure-lakehouse-starter-kit/databricks/notebooks/00_setup/create_catalog_schema",
        "base_parameters": {
          "environment": "dev",
          "catalog": "retail_lakehouse_dev"
        }
      },
      "existing_cluster_id": "<cluster-id>"
    },
    {
      "task_key": "bronze_customers",
      "depends_on": [{"task_key": "setup_catalog"}],
      "notebook_task": {
        "notebook_path": "/Repos/<repo>/azure-lakehouse-starter-kit/databricks/notebooks/01_bronze/ingest_customer_bronze",
        "base_parameters": {
          "catalog": "retail_lakehouse_dev",
          "batch_id": "{{job.run_id}}"
        }
      },
      "existing_cluster_id": "<cluster-id>"
    },
    {
      "task_key": "bronze_products",
      "depends_on": [{"task_key": "setup_catalog"}],
      "notebook_task": {
        "notebook_path": "/Repos/<repo>/azure-lakehouse-starter-kit/databricks/notebooks/01_bronze/ingest_product_bronze",
        "base_parameters": {
          "catalog": "retail_lakehouse_dev",
          "batch_id": "{{job.run_id}}"
        }
      },
      "existing_cluster_id": "<cluster-id>"
    },
    {
      "task_key": "bronze_orders",
      "depends_on": [{"task_key": "setup_catalog"}],
      "notebook_task": {
        "notebook_path": "/Repos/<repo>/azure-lakehouse-starter-kit/databricks/notebooks/01_bronze/ingest_order_bronze",
        "base_parameters": {
          "catalog": "retail_lakehouse_dev",
          "batch_id": "{{job.run_id}}"
        }
      },
      "existing_cluster_id": "<cluster-id>"
    },
    {
      "task_key": "silver_customers",
      "depends_on": [{"task_key": "bronze_customers"}],
      "notebook_task": {
        "notebook_path": "/Repos/<repo>/azure-lakehouse-starter-kit/databricks/notebooks/02_silver/clean_customer_silver",
        "base_parameters": {
          "catalog": "retail_lakehouse_dev",
          "batch_id": "{{job.run_id}}"
        }
      },
      "existing_cluster_id": "<cluster-id>"
    },
    {
      "task_key": "silver_products",
      "depends_on": [{"task_key": "bronze_products"}],
      "notebook_task": {
        "notebook_path": "/Repos/<repo>/azure-lakehouse-starter-kit/databricks/notebooks/02_silver/clean_product_silver",
        "base_parameters": {
          "catalog": "retail_lakehouse_dev",
          "batch_id": "{{job.run_id}}"
        }
      },
      "existing_cluster_id": "<cluster-id>"
    },
    {
      "task_key": "silver_orders",
      "depends_on": [{"task_key": "bronze_orders"}],
      "notebook_task": {
        "notebook_path": "/Repos/<repo>/azure-lakehouse-starter-kit/databricks/notebooks/02_silver/clean_order_silver",
        "base_parameters": {
          "catalog": "retail_lakehouse_dev",
          "batch_id": "{{job.run_id}}"
        }
      },
      "existing_cluster_id": "<cluster-id>"
    },
    {
      "task_key": "dq_required_checks",
      "depends_on": [
        {"task_key": "silver_customers"},
        {"task_key": "silver_products"},
        {"task_key": "silver_orders"}
      ],
      "notebook_task": {
        "notebook_path": "/Repos/<repo>/azure-lakehouse-starter-kit/databricks/notebooks/04_data_quality/dq_null_checks",
        "base_parameters": {
          "catalog": "retail_lakehouse_dev",
          "run_id": "{{job.run_id}}"
        }
      },
      "existing_cluster_id": "<cluster-id>"
    },
    {
      "task_key": "gold_dimensions",
      "depends_on": [{"task_key": "dq_required_checks"}],
      "notebook_task": {
        "notebook_path": "/Repos/<repo>/azure-lakehouse-starter-kit/databricks/notebooks/03_gold/build_dim_customer",
        "base_parameters": {
          "catalog": "retail_lakehouse_dev"
        }
      },
      "existing_cluster_id": "<cluster-id>"
    },
    {
      "task_key": "gold_fact_sales",
      "depends_on": [{"task_key": "gold_dimensions"}],
      "notebook_task": {
        "notebook_path": "/Repos/<repo>/azure-lakehouse-starter-kit/databricks/notebooks/03_gold/build_fact_sales",
        "base_parameters": {
          "catalog": "retail_lakehouse_dev"
        }
      },
      "existing_cluster_id": "<cluster-id>"
    }
  ],
  "tags": {
    "project": "azure-lakehouse-starter-kit",
    "domain": "retail-customer-analytics"
  }
}
