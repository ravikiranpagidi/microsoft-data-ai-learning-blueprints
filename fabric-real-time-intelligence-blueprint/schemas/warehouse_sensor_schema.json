{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Warehouse Sensor Event",
  "type": "object",
  "required": [
    "event_type",
    "warehouse_id",
    "zone_id",
    "temperature",
    "humidity",
    "vibration_level",
    "door_open",
    "event_timestamp"
  ],
  "properties": {
    "event_type": { "const": "warehouse" },
    "warehouse_id": { "type": "string", "pattern": "^WH-[A-Z]{3}-[0-9]{2}$" },
    "zone_id": { "type": "string" },
    "temperature": { "type": "number" },
    "humidity": { "type": "number", "minimum": 0, "maximum": 100 },
    "vibration_level": { "type": "number", "minimum": 0 },
    "door_open": { "type": "boolean" },
    "refrigerated_zone": { "type": "boolean" },
    "event_timestamp": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": true
}
